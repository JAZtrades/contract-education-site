# Application
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
PORT=3000
DATABASE_PATH=./data/app.sqlite
SESSION_SECRET=replace-with-at-least-32-random-bytes
ADMIN_EMAIL=attorney@example.com
ADMIN_INITIAL_PASSWORD=replace-with-one-time-initial-password

# Stripe test-mode keys only; never commit real keys
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_PUBLISHABLE_KEY=pk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy

# Payment limits, integer cents
PAYMENT_MIN_CENTS=750000
PAYMENT_MAX_CENTS=4000000
PAYMENT_HIGH_VALUE_CONFIRM_CENTS=2500000
CARD_PAYMENT_MAX_CENTS=1000000
